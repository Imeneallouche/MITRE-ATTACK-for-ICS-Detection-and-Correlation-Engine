{
    "id": "DC0067",
    "name": "Logon Session Creation",
    "type": "DataComponent",
    "description": "The successful establishment of a new user session following a successful authentication attempt. This typically signifies that a user has provided valid credentials or authentication tokens, and the system has initiated a session associated with that user account. This data is crucial for tracking authentication events and identifying potential unauthorized access.",
    "searchable_indexes": {
        "platforms": [
            "windows",
            "linux",
            "macos",
            "cloud",
            "saas",
            "network"
        ],
        "log_source_types": [
            "event_log",
            "syslog",
            "audit",
            "cloud_audit",
            "application",
            "endpoint",
            "network_flow"
        ],
        "indicator_types": [
            "ip",
            "username",
            "string"
        ],
        "categories": [
            "authentication",
            "user_session",
            "remote_access"
        ],
        "fields": [
            "EventID",
            "LogonType",
            "AccountName",
            "SourceNetworkAddress",
            "AuthenticationPackage",
            "ClientApp",
            "Location",
            "ActivityStatus",
            "OperationName"
        ],
        "keywords": [
            "4624",
            "utmp",
            "wtmp",
            "auth.log",
            "radius",
            "tacacs",
            "azure monitor",
            "last",
            "who",
            "logon type 2",
            "logon type 10",
            "successful_login",
            "accepted password",
            "accepted publickey",
            "accepted keyboard-interactive",
            "sshd",
            "ssh2",
            "pam_unix",
            "session opened",
            "logon_session_creation",
            "new session",
            "opened for user",
            "logged in"
        ]
    },
    "log_examples": {
        "windows": {
            "event_id": "4624",
            "description": "Successful Logon",
            "details": {
                "logon_types": [
                    "2 (Interactive)",
                    "10 (Remote Interactive via RDP)"
                ],
                "fields": {
                    "Account Name": "[Username]",
                    "Source Network Address": "[IP Address]",
                    "Authentication Package": "NTLM"
                }
            }
        },
        "linux": {
            "sources": [
                "/var/log/utmp",
                "/var/log/wtmp"
            ],
            "format_example": "login user [tty] from [source_ip]",
            "fields": {
                "User": "[Username]",
                "IP": "[IP Address]",
                "Timestamp": "[YYYY-MM-DD HH:MM:SS]"
            }
        },
        "macos": {
            "sources": [
                "/var/log/asl.log",
                "unified logging framework"
            ],
            "message_pattern": "com.apple.securityd: Authentication succeeded for user '[Username]'"
        },
        "cloud_environments": [
            {
                "platform": "Azure",
                "log_source": "Sign-In Logs",
                "details": {
                    "Activity": "Sign-in successful",
                    "Client App": "Browser",
                    "Location": "[Country/Region]"
                }
            },
            {
                "platform": "Google Workspace",
                "details": {
                    "Activity": "Login",
                    "Event Type": "successful_login",
                    "Source IP": "[IP Address]"
                }
            }
        ]
    },
    "collection_measures": {
        "windows": {
            "event_logs": {
                "event_id": "4624",
                "description": "Monitor Security Event Logs for successful logons."
            },
            "powershell": {
                "command": "Get-EventLog -LogName Security -InstanceId 4624"
            }
        },
        "linux": {
            "files": [
                "/var/log/utmp",
                "/var/log/wtmp",
                "/var/log/auth.log"
            ],
            "tools": [
                {
                    "command": "last",
                    "description": "Parse login records."
                },
                {
                    "command": "who",
                    "description": "Show who is logged on."
                }
            ]
        },
        "macos": {
            "files": [
                "/var/log/asl.log"
            ],
            "unified_logs": {
                "command": "log show --predicate 'eventMessage contains \"Authentication succeeded\"' --info"
            }
        },
        "cloud_environments": {
            "azure_ad": {
                "tool": "Azure Monitor",
                "cli_query": "az monitor log-analytics query -w <workspace_id> --analytics-query \"AzureActivity | where ActivityStatus == 'Success' and OperationName == 'Sign-in'\""
            },
            "google_workspace": {
                "source": "Login Audit logs (Admin Console)"
            },
            "office_365": {
                "source": "Audit Log Search (Security & Compliance Center)"
            }
        },
        "network_logs": {
            "sources": [
                "RADIUS",
                "TACACS"
            ]
        },
        "edr_monitoring": {
            "capabilities": [
                "Monitor logon session activity",
                "Track session attributes (source IP, duration, originating process)"
            ],
            "alert_configuration": [
                "Suspicious logon types (e.g., Type 10 RDP, Type 5 Service)",
                "Logons from unusual locations",
                "Logons from unusual devices"
            ]
        }
    },
