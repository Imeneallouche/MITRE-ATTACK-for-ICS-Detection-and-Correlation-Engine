{
    "id": "DC0002",
    "name": "User Account Authentication",
    "type": "DataComponent",
    "description": "An attempt (successful and failed login attempts) by a user, service, or application to gain access to a network, system, or cloud-based resource. This typically involves credentials such as passwords, tokens, multi-factor authentication (MFA), or biometric validation.",
    "searchable_indexes": {
        "platforms": [
            "windows",
            "linux",
            "macos",
            "cloud",
            "aws",
            "azure",
            "gcp",
            "saas",
            "containers",
            "kubernetes"
        ],
        "log_source_types": [
            "event_log",
            "audit",
            "cloud_audit",
            "application"
        ],
        "indicator_types": [
            "username",
            "ip",
            "user_agent"
        ],
        "categories": [
            "authentication",
            "credential_access",
            "lateral_movement",
            "insider_threat"
        ],
        "fields": [
            "User",
            "SourceIp",
            "LogonType",
            "Status",
            "FailureReason",
            "Service",
            "EventID",
            "AuthenticationMethod"
        ],
        "keywords": [
            "4624",
            "4625",
            "4776",
            "auth.log",
            "secure",
            "pam",
            "sign-in logs",
            "cloudtrail",
            "iam",
            "kubectl",
            "mfa"
        ]
    },
    "collection_measures": {
        "host_based_authentication": {
            "windows": {
                "event_logs": [
                    {
                        "event_id": "4776",
                        "description": "NTLM authentication attempt."
                    },
                    {
                        "event_id": "4624",
                        "description": "Successful user logon."
                    },
                    {
                        "event_id": "4625",
                        "description": "Failed authentication attempt."
                    },
                    {
                        "event_id": "4648",
                        "description": "Explicit logon with alternate credentials."
                    }
                ]
            },
            "linux_macos": {
                "log_files": [
                    "/var/log/auth.log",
                    "/var/log/secure"
                ],
                "audit_framework": {
                    "tool": "AuditD",
                    "description": "Tracks authentication events via PAM modules."
                },
                "macos_unified_logs": {
                    "path": "/var/db/diagnostics",
                    "description": "Captures authentication failures."
                }
            }
        },
        "cloud_authentication": {
            "azure_ad": {
                "logs": [
                    "Sign-in Logs (Tracks attempts, MFA, conditional access)",
                    "Audit Logs (Captures auth-related config changes)"
                ],
                "api": "Microsoft Graph API"
            },
            "google_workspace_office_365": {
                "google": {
                    "source": "Google Admin Console",
                    "report": "User Login Report"
                },
                "office_365": {
                    "source": "Unified Audit Logs",
                    "scope": [
                        "Exchange",
                        "SharePoint",
                        "Teams"
                    ]
                }
            },
            "aws": {
                "source": "CloudTrail & IAM",
                "events": [
                    "AWS IAM AuthenticateUser",
                    "sts:GetSessionToken"
                ],
                "description": "Logs failed authentications to Console and API requests."
            }
        },
        "container_authentication": {
            "kubernetes": {
                "logs": "kubectl audit logs",
                "description": "Captures authentication attempts for service accounts and admin users."
            },
            "managed_k8s": {
                "platforms": [
                    "Azure Kubernetes Service (AKS)",
                    "Google Kubernetes Engine (GKE)"
                ],
                "description": "Logs IAM authentication events."
            }
        }
    },
